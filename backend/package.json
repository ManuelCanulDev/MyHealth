{
  "name": "myhealth",
  "version": "1.0.0",
  "description": "MyHealth: ficha medica y contactos on-chain (Monad) + API Node",
  "main": "backend/server.js",
  "scripts": {
    "compile": "truffle compile",
    "migrate:monad": "truffle migrate --network monadTestnet",
    "forge:build": "PATH=\"$HOME/.foundry/bin:$PATH\" forge build",
    "forge:deploy:monad": "bash scripts/deploy-monad.sh",
    "start": "node backend/server.js",
    "check": "bash scripts/validate.sh",
    "check:fast": "npm run forge:build && node --check backend/server.js && node scripts/check-onchain.cjs"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.3.0",
    "web3": "^1.10.4"
  },
  "devDependencies": {
    "@truffle/hdwallet-provider": "^2.1.5",
    "truffle": "^5.11.5"
  }
}
