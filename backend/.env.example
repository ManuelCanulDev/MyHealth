# Frase BIP39 valida (12/24 palabras) para desplegar con Truffle
MNEMONIC=

# RPC (por defecto testnet publica Monad)
# MONAD_RPC=https://testnet-rpc.monad.xyz

# Tras `truffle migrate --network monadTestnet' o `npm run forge:deploy:monad' (nombre/apellido/teléfono/correo van on-chain en el contrato actual) y REINICIA el servidor
MYHEALTH_CONTRACT_ADDRESS=

# Cuenta que firma transacciones (0x...), debe ser una de las derivadas del MNEMONIC o la misma clave
CUENTA=

# Clave privada de la cuenta (con o sin 0x) — solo en servidor seguro
# Tambien usada por Foundry: npm run forge:deploy:monad
PRIVATE_KEY=

# API Node
# PORT=3000

# Opcional: si se define, POST/DELETE /api/mapa-de-emergencias/alerta exigen Authorization: Bearer <valor> o header X-Mapa-Key
# MAPA_EMERGENCIA_KEY=

# Si es 1 o true: las alertas del mapa se leen/escriben en el contrato MyHealth (registrarEmergenciaMapa / limpiarEmergenciaMapa).
# Requiere redeploy del contrato con el código actual, MYHEALTH_CONTRACT_ADDRESS actualizado, PRIVATE_KEY y forge build.
# MAPA_EMERGENCIA_ONCHAIN=0

# Twilio (SMS) — opcional
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# SendGrid (email) — opcional
# SENDGRID_API_KEY=
# SENDGRID_FROM=
